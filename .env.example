# Stripe 真实支付（Get your keys at https://dashboard.stripe.com/test/apikeys）
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=

# 管理后台保护。设置后，访问 /orders、/upload、/chat 等私有接口需带 ?admin_token=... 或 X-Admin-Token header
ADMIN_TOKEN=change_me_to_a_long_random_value
SECRET_KEY=change_me_to_another_long_random_value

# 云端模型 API Key。不要写进代码或提交真实值
ZHIPU_API_KEY=
SILICONFLOW_API_KEY=

# 可选 Coze Widget。留空则不注入 Coze 脚本
COZE_BOT_ID=
COZE_TOKEN=

# 诊断报告价格，单位为分
AUDIT_PRICE_CENTS=499
AUDIT_PRICE_CURRENCY=usd

# 公网域名（部署到云服务器后改为实际域名，如 https://your-domain.com）
PUBLIC_DOMAIN=http://localhost:8080
